# PIVX Bridge configuration
# Copy to .env and adjust as needed.

RPC_URL=http://127.0.0.1:51473
RPC_USER=rpc
RPC_PASS=rpc
ZMQ_URL=tcp://127.0.0.1:28332
PORT=3000

# Sapling activation height (mainnet default: 2700501)
# SAPLING_HEIGHT=2700501

# Comma-separated list of allowed RPC methods for the proxy endpoint
# ALLOWED_RPCS=getblockcount,getblockhash,getblock,getrawtransaction,sendrawtransaction,getmasternodecount,listmasternodes,getbudgetprojection,getbudgetinfo,getbudgetvotes
